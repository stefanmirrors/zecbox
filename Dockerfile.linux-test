FROM ubuntu:22.04 AS base

ENV DEBIAN_FRONTEND=noninteractive
ENV CARGO_HOME=/usr/local/cargo
ENV RUSTUP_HOME=/usr/local/rustup
ENV PATH="$CARGO_HOME/bin:$PATH"

# System dependencies for Tauri v2 on Linux
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    file \
    libwebkit2gtk-4.1-dev \
    libgtk-3-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    patchelf \
    libssl-dev \
    pkg-config \
    wget \
    iptables \
    iproute2 \
    lsof \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
RUN rustup target add x86_64-unknown-linux-gnu

# Install Node.js 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Tauri CLI
RUN npm install -g @tauri-apps/cli@latest

WORKDIR /app

# Copy dependency files first for caching
COPY Cargo.toml Cargo.lock ./
COPY src-tauri/Cargo.toml src-tauri/Cargo.toml
COPY src-tauri/build.rs src-tauri/build.rs
COPY firewall-helper/Cargo.toml firewall-helper/Cargo.toml
COPY mock-zebrad/Cargo.toml mock-zebrad/Cargo.toml
COPY mock-arti/Cargo.toml mock-arti/Cargo.toml
COPY mock-zaino/Cargo.toml mock-zaino/Cargo.toml

# Copy package.json for npm install caching
COPY package.json package-lock.json ./

RUN npm ci

# Copy the full source
COPY . .

# ========================= Build Stage =========================
FROM base AS build

# Build mock sidecars
RUN for binary in zebrad arti zaino; do \
        cargo build -p "mock-${binary}" --release && \
        cp "target/release/mock-${binary}" "src-tauri/binaries/${binary}-x86_64-unknown-linux-gnu" && \
        chmod +x "src-tauri/binaries/${binary}-x86_64-unknown-linux-gnu"; \
    done

# Build firewall helper
RUN cargo build -p firewall-helper --release && \
    cp target/release/zecbox-firewall-helper src-tauri/binaries/zecbox-firewall-helper-x86_64-unknown-linux-gnu && \
    chmod +x src-tauri/binaries/zecbox-firewall-helper-x86_64-unknown-linux-gnu

# Build the full Tauri app
RUN npx tauri build 2>&1 || true

# ========================= Test Stage =========================
FROM base AS test

COPY --from=build /app/target /app/target
COPY --from=build /app/src-tauri/binaries /app/src-tauri/binaries

COPY scripts/test-linux-docker.sh /app/scripts/test-linux-docker.sh
RUN chmod +x /app/scripts/test-linux-docker.sh

CMD ["/app/scripts/test-linux-docker.sh"]
