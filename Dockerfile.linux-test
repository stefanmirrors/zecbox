FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV CARGO_HOME=/usr/local/cargo
ENV RUSTUP_HOME=/usr/local/rustup
ENV PATH="$CARGO_HOME/bin:$PATH"

# System dependencies for Tauri v2 on Linux
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    file \
    libwebkit2gtk-4.1-dev \
    libgtk-3-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    patchelf \
    libssl-dev \
    pkg-config \
    wget \
    iptables \
    iproute2 \
    lsof \
    socat \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable

# Install Node.js 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Detect host triple and store it for subsequent RUN steps
RUN echo $(rustc -vV | grep host | awk '{print $2}') > /tmp/target-triple

WORKDIR /app

# Copy everything (respects .dockerignore)
COPY . .

# Install frontend dependencies
RUN npm ci

# Create binaries dir (excluded by .dockerignore)
RUN mkdir -p src-tauri/binaries

# Build mock sidecars using detected triple
RUN TRIPLE=$(cat /tmp/target-triple) && \
    for binary in zebrad arti zaino; do \
        cargo build -p "mock-${binary}" --release && \
        cp "target/release/mock-${binary}" "src-tauri/binaries/${binary}-${TRIPLE}" && \
        chmod +x "src-tauri/binaries/${binary}-${TRIPLE}"; \
    done

# Build firewall helper
RUN TRIPLE=$(cat /tmp/target-triple) && \
    cargo build -p firewall-helper --release && \
    cp target/release/zecbox-firewall-helper "src-tauri/binaries/zecbox-firewall-helper-${TRIPLE}" && \
    chmod +x "src-tauri/binaries/zecbox-firewall-helper-${TRIPLE}"

# Build the full Tauri app
RUN npx tauri build || true

# Copy test script and make executable
RUN chmod +x scripts/test-linux-docker.sh

CMD ["scripts/test-linux-docker.sh"]
