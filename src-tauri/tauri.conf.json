{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "zecbox",
  "version": "0.1.1",
  "identifier": "com.zecbox.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "zecbox",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://zecbox.io/updates/app-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDMDVDRDQwRjQxRkEzREQKUldUZG94LzBRTTBGSENWb2NmK1BDazhub3RWNkpPS2dZMGR5a3JyL3FpVlROaStuS2JscXQ0K2YK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb", "nsis"],
    "category": "public.app-category.utilities",
    "copyright": "zecbox Contributors",
    "externalBin": ["binaries/zebrad", "binaries/arti", "binaries/zaino", "binaries/zecbox-firewall-helper"],
    "resources": ["binaries/WinDivert.dll", "binaries/WinDivert64.sys"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": null,
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
