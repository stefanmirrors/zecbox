---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import DashboardDemo from "../components/DashboardDemo.astro";
import Features from "../components/Features.astro";
import Download from "../components/Download.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 border-b border-zec-border backdrop-blur-md" style="background:rgba(13,17,23,0.85);">
    <div class="flex items-center px-6 py-2">
      <a href="#" class="flex items-center gap-2 mr-8 no-underline">
        <img src="/zecbox-icon.png" alt="" class="w-6 h-6" />
        <span class="text-sm font-semibold text-zec-yellow tracking-tight" style="font-family:'Montserrat',sans-serif;">zecbox</span>
      </a>
      <div class="flex items-center gap-1">
        <a href="#how-it-works" class="site-tab px-4 py-1.5 rounded-lg text-sm font-medium text-zec-muted hover:text-zec-text transition-colors no-underline">How it works</a>
        <a href="#app-demo" class="site-tab px-4 py-1.5 rounded-lg text-sm font-medium text-zec-muted hover:text-zec-text transition-colors no-underline">App demo</a>
      </div>
    </div>
  </nav>
  <div class="pt-11">
    <Hero />
  </div>
  <div id="how-it-works" class="scroll-mt-11">
    <Features />
  </div>
  <div id="app-demo" class="scroll-mt-11">
    <DashboardDemo />
  </div>
  <script>
    const tabs = document.querySelectorAll('.site-tab');
    const sections = [document.getElementById('how-it-works'), document.getElementById('app-demo')];
    function updateActive() {
      const y = window.scrollY + 80;
      let active = 0;
      sections.forEach((s, i) => { if (s && s.offsetTop <= y) active = i; });
      tabs.forEach((t, i) => {
        if (i === active) { t.className = 'site-tab px-4 py-1.5 rounded-lg text-sm font-medium text-zec-yellow transition-colors'; }
        else { t.className = 'site-tab px-4 py-1.5 rounded-lg text-sm font-medium text-zec-muted hover:text-zec-text transition-colors'; }
      });
    }
    window.addEventListener('scroll', updateActive);
    updateActive();
  </script>
  <Download />
  <Footer />
</Base>
