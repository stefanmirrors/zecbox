---
---

<footer class="border-t border-zec-border px-6 py-10">
  <div
    class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <div class="flex items-center gap-2">
      <img src="/zecbox-icon.png" alt="" class="w-6 h-6" />
      <span class="text-sm font-semibold text-zec-text">zecbox</span>
    </div>
    <div class="flex items-center gap-6">
      <a
        href="/network"
        class="text-sm text-zec-muted hover:text-zec-text transition-colors"
      >
        Network
      </a>
      <a
        href="https://github.com/stefanmirrors/zecbox"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zec-muted hover:text-zec-text transition-colors"
      >
        GitHub
      </a>
      <a
        href="https://github.com/stefanmirrors/zecbox/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zec-muted hover:text-zec-text transition-colors"
      >
        Releases
      </a>
      <a
        href="https://x.com/zecbox_io"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zec-muted hover:text-zec-text transition-colors flex items-center gap-1.5"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        @zecbox_io
      </a>
    </div>
    <p class="text-xs text-zec-muted">
      &copy; {new Date().getFullYear()} zecbox Contributors
    </p>
  </div>
</footer>
