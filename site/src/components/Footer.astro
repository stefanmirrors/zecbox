---
---

<footer class="border-t border-zec-border px-6 py-10">
  <div
    class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4"
  >
    <div class="flex items-center gap-2">
      <img src="/zecbox-icon.png" alt="" class="w-6 h-6" />
      <span class="text-sm font-semibold text-zec-text">zecbox</span>
    </div>
    <div class="flex items-center gap-6">
      <a
        href="/network"
        class="text-sm text-zec-muted hover:text-zec-text transition-colors"
      >
        Network
      </a>
      <a
        href="https://github.com/stefanmirrors/zecbox"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zec-muted hover:text-zec-text transition-colors"
      >
        GitHub
      </a>
      <a
        href="https://github.com/stefanmirrors/zecbox/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-zec-muted hover:text-zec-text transition-colors"
      >
        Releases
      </a>
    </div>
    <p class="text-xs text-zec-muted">
      &copy; {new Date().getFullYear()} zecbox Contributors
    </p>
  </div>
</footer>
