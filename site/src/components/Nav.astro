---
interface Props {
  activePage?: "home" | "network";
}

const { activePage = "home" } = Astro.props;
const isNetwork = activePage === "network";
---

<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl" style="background:rgba(13,17,23,0.6);">
  <div class="flex items-center px-4 sm:px-6 py-2">
    <a href="/" class="flex items-center mr-4 sm:mr-8 no-underline shrink-0">
      <span class="text-base font-bold text-zec-yellow tracking-tight" style="font-family:'Montserrat',sans-serif;">zecbox</span>
    </a>
    <div class="flex items-center flex-1 gap-0">
      <a href="/#how-it-works" class={`site-tab flex-1 text-center px-1 sm:px-4 py-1.5 rounded-lg text-xs sm:text-sm font-medium transition-colors no-underline whitespace-nowrap ${isNetwork ? 'text-zec-muted hover:text-zec-text' : 'text-zec-muted hover:text-zec-text'}`}>How it works</a>
      <a href="/#app-demo" class={`site-tab flex-1 text-center px-1 sm:px-4 py-1.5 rounded-lg text-xs sm:text-sm font-medium transition-colors no-underline whitespace-nowrap ${isNetwork ? 'text-zec-muted hover:text-zec-text' : 'text-zec-muted hover:text-zec-text'}`}>App demo</a>
      <a href="/#network" class={`site-tab flex-1 text-center px-1 sm:px-4 py-1.5 rounded-lg text-xs sm:text-sm font-medium transition-colors no-underline whitespace-nowrap ${isNetwork ? 'text-zec-yellow' : 'text-zec-muted hover:text-zec-text'}`}>Network</a>
      <a href="/#downloads" class={`site-tab flex-1 text-center px-1 sm:px-4 py-1.5 rounded-lg text-xs sm:text-sm font-medium transition-colors no-underline whitespace-nowrap ${isNetwork ? 'text-zec-muted hover:text-zec-text' : 'text-zec-muted hover:text-zec-text'}`}>Downloads</a>
    </div>
  </div>
  <div class="flex items-center justify-center px-4 py-1.5 text-xs font-medium tracking-wide text-zec-muted border-t border-white/5">
    Beta
  </div>
</nav>

{!isNetwork && (
  <script>
    const ACT = 'site-tab flex-1 text-center px-1 sm:px-4 py-1.5 rounded-lg text-xs sm:text-sm font-medium text-zec-yellow transition-colors no-underline whitespace-nowrap';
    const INACT = 'site-tab flex-1 text-center px-1 sm:px-4 py-1.5 rounded-lg text-xs sm:text-sm font-medium text-zec-muted hover:text-zec-text transition-colors no-underline whitespace-nowrap';
    const tabs = document.querySelectorAll('.site-tab');
    const sectionIds = ['how-it-works', 'app-demo', 'network', 'downloads'];
    const sectionEls = sectionIds.map(id => document.getElementById(id));
    function updateActive() {
      const atBottom = (window.innerHeight + window.scrollY) >= (document.body.scrollHeight - 50);
      let active = -1;
      if (atBottom) {
        active = sectionIds.length - 1;
      } else {
        const trigger = window.scrollY + window.innerHeight * 0.35;
        sectionEls.forEach((s, i) => { if (s && s.offsetTop <= trigger) active = i; });
      }
      tabs.forEach((t, i) => { (t as HTMLElement).className = i === active ? ACT : INACT; });
    }
    window.addEventListener('scroll', updateActive);
    updateActive();
  </script>
)}

<style is:global>
  #site-nav a { text-decoration: none !important; }
</style>
