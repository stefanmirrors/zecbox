---
let version = "0.1.2";
try {
  const res = await fetch("https://api.github.com/repos/stefanmirrors/zecbox/releases/latest");
  if (res.ok) {
    const data = await res.json();
    version = data.tag_name?.replace("v", "") ?? version;
  }
} catch {}

const downloads = {
  macos: {
    arm: { url: "https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-aarch64.dmg", label: "Download for macOS", arch: "Apple Silicon (M1–M4)" },
    intel: { url: "https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-x86_64.dmg", label: "Download for macOS", arch: "Intel" },
  },
  linux: {
    x86_64: { url: "https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-linux-x86_64.deb", label: "Download for Linux", arch: "Intel/AMD (x86_64)" },
    arm64: { url: "https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-linux-aarch64.deb", label: "Download for Linux", arch: "ARM (aarch64)" },
  },
  windows: {
    x86_64: { url: "https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-windows-x86_64.exe", label: "Download for Windows", arch: "Intel/AMD (x86_64)" },
  },
};
