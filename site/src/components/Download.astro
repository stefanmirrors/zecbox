      </div>
      </details>
    </div>

    <script>
      // Platform detection — show primary download button + highlight detected card
      (function () {
        const data = JSON.parse(document.getElementById('download-data')?.textContent || '{}');
        const ua = navigator.userAgent;
        const platform = (navigator.platform || '').trim();
        const uaData = (navigator as any).userAgentData;

        if (/Android|iPhone|iPad|iPod|Mobile/i.test(ua)) return;

        let os = 'unknown';
        let arch = 'unknown';

        if (ua.includes('Mac OS X') || platform.startsWith('Mac')) {
          os = 'macos';
          arch = uaData?.architecture === 'x86' ? 'intel' : 'arm';
        } else if (ua.includes('CrOS') || (ua.includes('Linux') && !ua.includes('Android'))) {
          os = 'linux';
          const isArm = uaData?.architecture === 'arm' || /aarch64|armv[78]l/i.test(platform) || /aarch64|armv[78]l/i.test(ua);
          arch = isArm ? 'arm64' : 'x86_64';
        } else if (ua.includes('Windows')) {
          os = 'windows';
          arch = 'x86_64';
        }

        if (os === 'unknown') return;

        // Resolve download info
        let dl: { url: string; label: string; arch: string } | undefined;
        if (os === 'macos') dl = arch === 'intel' ? data.macos?.intel : data.macos?.arm;
        else if (os === 'linux') dl = arch === 'arm64' ? data.linux?.arm64 : data.linux?.x86_64;
        else if (os === 'windows') dl = data.windows?.x86_64;

        if (!dl) return;

        // Show auto-detected download button
        const primary = document.getElementById('detected-download');
        const btn = document.getElementById('detected-download-btn') as HTMLAnchorElement;
        const btnText = document.getElementById('detected-btn-text');
        const archLabel = document.getElementById('detected-arch-label');
        if (primary && btn && btnText) {
          btn.href = dl.url;
          btnText.textContent = dl.label;
          if (archLabel) archLabel.textContent = dl.arch;
          primary.classList.remove('hidden');
        }

        // Highlight detected platform card with badge + border
        const card = document.querySelector(`[data-platform-card="${os}"]`) as HTMLElement;
        if (card) {
          const badge = card.querySelector('[data-detected-badge]') as HTMLElement;
          if (badge) badge.classList.remove('hidden');
          card.classList.remove('border-zec-border');
          card.classList.add('border-zec-yellow/40');
        }

        // Show only the detected platform's post-install instructions
        const showPlatforms = os === 'macos' ? ['macos'] : os === 'linux' ? ['linux-deb'] : ['windows'];
        document.querySelectorAll<HTMLElement>('[data-platform]').forEach(el => {
          if (!showPlatforms.includes(el.dataset.platform!)) el.classList.add('hidden');
        });
        document.querySelectorAll<HTMLElement>('[data-platform-divider]').forEach(el => el.classList.add('hidden'));

        // Show the "all platforms" toggle and wire it up
        const toggleWrap = document.getElementById('show-all-instructions');
        if (toggleWrap) {
          toggleWrap.classList.remove('hidden');
          let expanded = false;
          const toggleBtn = toggleWrap.querySelector('button')!;
          const btnLabel = toggleBtn.querySelector('span')!;
          toggleBtn.addEventListener('click', () => {
            expanded = !expanded;
            if (expanded) {
              document.querySelectorAll<HTMLElement>('[data-platform]').forEach(el => el.classList.remove('hidden'));
              document.querySelectorAll<HTMLElement>('[data-platform-divider]').forEach(el => el.classList.remove('hidden'));
              btnLabel.textContent = 'Show only my platform';
            } else {
              document.querySelectorAll<HTMLElement>('[data-platform]').forEach(el => {
                if (!showPlatforms.includes(el.dataset.platform!)) el.classList.add('hidden');
              });
              document.querySelectorAll<HTMLElement>('[data-platform-divider]').forEach(el => el.classList.add('hidden'));
              btnLabel.textContent = 'Show instructions for all platforms';
            }
          });
        }
      })();

      // Copy-to-clipboard handler
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const targetId = btn.getAttribute('data-target');
          const cmd = document.getElementById(targetId ?? '')?.textContent ?? '';
          await navigator.clipboard.writeText(cmd);
          const copyIcon = btn.querySelector('.copy-icon');
          const checkIcon = btn.querySelector('.check-icon');
          if (copyIcon && checkIcon) {
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              checkIcon.classList.add('hidden');
            }, 2000);
          }
        });
      });
    </script>
    <style>
      #install-instructions[open] .details-chevron { transform: rotate(180deg); }
    </style>
  </div>
