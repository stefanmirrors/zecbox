---
let version = "0.1.2";
try {
  const res = await fetch("https://api.github.com/repos/stefanmirrors/zecbox/releases/latest");
  if (res.ok) {
    const data = await res.json();
    version = data.tag_name?.replace("v", "") ?? version;
  }
} catch {}

const downloads = {
  macos: {
    arm: {
      url: "https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-aarch64.dmg",
      label: "Download .dmg",
      arch: "Apple Silicon (M1\u2013M4)",
    },
    intel: {
      url: "https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-x86_64.dmg",
      label: "Download .dmg",
      arch: "Intel",
    },
  },
  linux: {
    x86_64: {
      url: `https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox_${version}_amd64.AppImage`,
      label: "Download .AppImage",
      arch: "x86_64",
    },
    arm64: {
      url: `https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox_${version}_aarch64.AppImage`,
      label: "Download .AppImage",
      arch: "ARM64",
    },
  },
};
---

