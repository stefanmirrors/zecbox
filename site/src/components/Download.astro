    <script>
      // Platform detection and primary download button
      (function () {
        const data = JSON.parse(document.getElementById('download-data')?.textContent || '{}');
        const ua = navigator.userAgent;
        const platform = navigator.platform || '';
        const uaData = (navigator as any).userAgentData;

        let os = 'unknown';
        let arch = 'unknown';

        if (ua.includes('Mac OS X') || platform.startsWith('Mac')) {
          os = 'macos';
        } else if (ua.includes('Linux') && !ua.includes('Android')) {
          os = 'linux';
        } else if (ua.includes('Windows')) {
          os = 'windows';
        }

        if (os === 'macos') {
          arch = uaData?.architecture === 'x86' ? 'intel' : 'arm';
        } else if (os === 'linux') {
          if (uaData?.architecture === 'arm' || platform.includes('aarch64') || platform.includes('arm')) {
            arch = 'arm64';
          } else {
            arch = 'x86_64';
          }
        }

        if (os === 'unknown') return;

        const primary = document.getElementById('detected-download');
        const allDownloads = document.getElementById('all-downloads');
        if (!primary || !allDownloads) return;

        const icon = primary.querySelector(`[data-os-icon="${os}"]`);
        if (icon) icon.classList.remove('hidden');

        const osLabel = document.getElementById('detected-os-label')!;
        const archLabel = document.getElementById('detected-arch-label')!;
        const btn = document.getElementById('detected-download-btn') as HTMLAnchorElement;
        const btnText = document.getElementById('detected-btn-text')!;
        const windowsNotice = document.getElementById('detected-windows-notice')!;

        if (os === 'windows') {
          osLabel.textContent = 'Download for Windows';
          archLabel.textContent = '';
          btn.classList.add('hidden');
          windowsNotice.classList.remove('hidden');
        } else if (os === 'macos') {
          const d = arch === 'intel' ? data.macos?.intel : data.macos?.arm;
          osLabel.textContent = 'Download for macOS';
          archLabel.textContent = d?.arch || '';
          btn.href = d?.url || '#';
          btnText.textContent = d?.label || 'Download';

          const isSafari = !uaData && /Safari/.test(ua) && !/Chrome/.test(ua);
          if (isSafari) {
            document.getElementById('arch-helper')?.classList.remove('hidden');
          }
        } else if (os === 'linux') {
          const d = arch === 'arm64' ? data.linux?.arm64 : data.linux?.x86_64;
          osLabel.textContent = 'Download for Linux';
          archLabel.textContent = d?.arch || '';
          btn.href = d?.url || '#';
          btnText.textContent = d?.label || 'Download';
        }

        primary.classList.remove('hidden');
        allDownloads.classList.add('hidden');

        // Determine which post-install sections to show
        // macOS → show "macos", Linux → show "linux-appimage" (default download format)
        const showPlatforms = os === 'macos' ? ['macos'] : os === 'linux' ? ['linux-appimage'] : [];

        document.querySelectorAll<HTMLElement>('[data-platform]').forEach(el => {
          if (!showPlatforms.includes(el.dataset.platform!)) el.classList.add('hidden');
        });
        document.querySelector<HTMLElement>('[data-platform-divider]')?.classList.add('hidden');

        // Toggle "Other downloads"
        let expanded = false;
        document.getElementById('show-all-downloads')?.addEventListener('click', () => {
          expanded = !expanded;
          allDownloads.classList.toggle('hidden', !expanded);
          const arrow = document.querySelector('.toggle-arrow');
          if (arrow) arrow.textContent = expanded ? '\u2191' : '\u2193';

          if (expanded) {
            document.querySelectorAll<HTMLElement>('[data-platform]').forEach(el => el.classList.remove('hidden'));
            document.querySelector<HTMLElement>('[data-platform-divider]')?.classList.remove('hidden');
          } else {
            document.querySelectorAll<HTMLElement>('[data-platform]').forEach(el => {
              if (!showPlatforms.includes(el.dataset.platform!)) el.classList.add('hidden');
            });
            document.querySelector<HTMLElement>('[data-platform-divider]')?.classList.add('hidden');
          }
        });
      })();

      // Copy-to-clipboard handler
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const targetId = btn.getAttribute('data-target');
          const cmd = document.getElementById(targetId ?? '')?.textContent ?? '';
          await navigator.clipboard.writeText(cmd);
          const copyIcon = btn.querySelector('.copy-icon');
          const checkIcon = btn.querySelector('.check-icon');
          if (copyIcon && checkIcon) {
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              checkIcon.classList.add('hidden');
            }, 2000);
          }
        });
      });
    </script>
  </div>
</section>
