---
let version = "0.1.2";
try {
  const res = await fetch("https://api.github.com/repos/stefanmirrors/zecbox/releases/latest");
  if (res.ok) {
    const data = await res.json();
    version = data.tag_name?.replace("v", "") ?? version;
  }
} catch {}
---

<section class="px-4 sm:px-6 pt-6 sm:pt-10 pb-8 sm:pb-12">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-8">
      <h2 class="text-3xl sm:text-4xl font-black text-zec-text mb-2" style="font-family: 'Montserrat', sans-serif;">Downloads</h2>
      <p class="text-zec-muted">v{version} · ~300 GB disk space required for the full blockchain</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <!-- macOS -->
      <div class="border border-zec-border rounded-xl p-4">
        <div class="flex items-center gap-2.5 mb-3">
          <svg class="w-6 h-6 text-zec-text shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <div>
            <p class="text-sm font-semibold text-zec-text">macOS</p>
            <p class="text-[11px] text-zec-muted">12+ required</p>
          </div>
        </div>
        <div class="space-y-1.5">
          <a
            href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-aarch64.dmg"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between px-3 py-2 rounded-md bg-zec-yellow text-zec-dark font-semibold text-xs hover:brightness-110 transition-all no-underline"
          >
            Apple Silicon
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          </a>
          <a
            href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-x86_64.dmg"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between px-3 py-2 rounded-md border border-zec-border text-zec-text font-medium text-xs hover:border-zec-muted transition-all no-underline"
          >
            Intel
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          </a>
        </div>
      </div>

      <!-- Linux -->
      <div class="border border-zec-border rounded-xl p-4">
        <div class="flex items-center gap-2.5 mb-3">
          <svg class="w-6 h-6 text-zec-text shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a11.966 11.966 0 00-2.517 2.453c-1.455 1.774-.41 3.178 1.382 3.178h1.369c.193 0 .398-.043.608-.13.573.402 1.181.756 1.82 1.05a8.41 8.41 0 002.596.738c.344.034.682.055 1.006.055.397 0 .776-.032 1.126-.089a8.476 8.476 0 002.847-.907 9.588 9.588 0 001.654-.942c.203.074.4.11.588.11h1.369c1.792 0 2.837-1.404 1.382-3.178a11.966 11.966 0 00-2.517-2.453c.123-.805-.01-1.657-.287-2.489-.59-1.771-1.831-3.47-2.716-4.521-.75-1.067-.974-1.928-1.05-3.02-.065-1.491 1.056-5.965-3.17-6.298A5.11 5.11 0 0012.504 0zm0 1.5c.076 0 .154.003.236.012 2.33.184 2.058 3.27 2.12 4.688.066 1.325.376 2.47 1.25 3.715.818.971 1.942 2.494 2.46 4.05.208.625.322 1.26.236 1.836-.56-.326-1.155-.604-1.779-.826a6.92 6.92 0 00-.754-.227c.21-.578.105-1.238-.31-1.787-.543-.717-1.47-1.088-2.459-1.088s-1.916.371-2.459 1.088c-.415.549-.52 1.209-.31 1.787a6.92 6.92 0 00-.754.227 10.164 10.164 0 00-1.779.826c-.086-.576.028-1.211.236-1.836.518-1.556 1.642-3.079 2.46-4.05.874-1.245 1.184-2.39 1.25-3.715.062-1.418-.21-4.504 2.12-4.688.082-.009.16-.012.236-.012z"/></svg>
          <div>
            <p class="text-sm font-semibold text-zec-text">Linux</p>
          </div>
        </div>
        <p class="text-[10px] text-zec-muted mb-1.5 font-medium uppercase tracking-wider">x86_64</p>
        <div class="space-y-1.5">
          <a
            href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox_0.1.7_amd64.AppImage"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between px-3 py-2 rounded-md bg-zec-yellow text-zec-dark font-semibold text-xs hover:brightness-110 transition-all no-underline"
          >
            AppImage
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          </a>
          <a
            href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox_0.1.7_amd64.deb"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between px-3 py-2 rounded-md border border-zec-border text-zec-text font-medium text-xs hover:border-zec-muted transition-all no-underline"
          >
            .deb
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          </a>
        </div>
        <p class="text-[10px] text-zec-muted mb-1.5 mt-3 font-medium uppercase tracking-wider">ARM64</p>
        <div class="space-y-1.5">
          <a
            href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox_0.1.7_aarch64.AppImage"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between px-3 py-2 rounded-md bg-zec-yellow text-zec-dark font-semibold text-xs hover:brightness-110 transition-all no-underline"
          >
            AppImage
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          </a>
          <a
            href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox_0.1.7_arm64.deb"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between px-3 py-2 rounded-md border border-zec-border text-zec-text font-medium text-xs hover:border-zec-muted transition-all no-underline"
          >
            .deb
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          </a>
        </div>
      </div>

      <!-- Windows -->
      <div class="border border-zec-border/50 rounded-xl p-4 opacity-50">
        <div class="flex items-center gap-2.5 mb-3">
          <svg class="w-6 h-6 text-zec-text shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M3 12V6.75l8-1.25V12H3zm0 .5h8v6.5l-8-1.25V12.5zM11.5 5.34l9.5-1.34v8h-9.5V5.34zM11.5 12.5H21v7.5l-9.5-1.34V12.5z"/></svg>
          <div>
            <p class="text-sm font-semibold text-zec-text">Windows</p>
            <p class="text-[11px] text-zec-muted">Coming soon</p>
          </div>
        </div>
        <div class="px-3 py-2 rounded-md border border-zec-border/50 text-xs text-zec-muted text-center">
          In development
        </div>
      </div>
    </div>

    <!-- Post-install steps -->
    <div class="mt-6 bg-zec-surface border border-zec-border rounded-xl p-5">
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-5 h-5 text-zec-yellow shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <h3 class="text-sm font-semibold text-zec-text">After Installing</h3>
        <span class="text-[10px] font-medium text-zec-muted bg-zec-dark border border-zec-border rounded px-1.5 py-0.5">macOS</span>
      </div>

      <ol class="space-y-3 text-sm text-zec-muted list-none m-0 p-0">
        <li class="flex gap-3">
          <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">1</span>
          <span>Open the <strong class="text-zec-text">.dmg</strong> and drag ZecBox into Applications</span>
        </li>
        <li class="flex gap-3">
          <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">2</span>
          <span>Open <strong class="text-zec-text">Terminal</strong> — press <kbd class="text-[11px] bg-zec-dark border border-zec-border rounded px-1.5 py-0.5 text-zec-text font-sans">&#8984; Space</kbd> and type "Terminal"</span>
        </li>
        <li class="flex gap-3">
          <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">3</span>
          <div class="flex-1 min-w-0">
            <span>Paste this command and press Enter:</span>
            <div class="mt-1.5 flex items-center gap-2 bg-zec-dark border border-zec-border rounded-lg px-3 py-2">
              <code class="text-xs font-mono text-zec-text select-all flex-1 min-w-0" id="xattr-cmd">xattr -cr /Applications/zecbox.app</code>
              <button
                type="button"
                class="shrink-0 p-1 rounded hover:bg-zec-border transition-colors text-zec-muted hover:text-zec-text copy-btn"
                data-target="xattr-cmd"
                title="Copy to clipboard"
              >
                <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg>
                <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </button>
            </div>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">4</span>
          <span>Open <strong class="text-zec-text">ZecBox</strong> from Applications</span>
        </li>
      </ol>

      <p class="mt-4 text-xs text-zec-muted">macOS blocks apps from unidentified developers. This command removes that restriction. Code signing is coming soon.</p>
    </div>

    <!-- Linux post-install -->
    <div class="mt-3 bg-zec-surface border border-zec-border rounded-xl p-5">
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-5 h-5 text-zec-yellow shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <h3 class="text-sm font-semibold text-zec-text">After Installing</h3>
        <span class="text-[10px] font-medium text-zec-muted bg-zec-dark border border-zec-border rounded px-1.5 py-0.5">Linux</span>
      </div>

      <div class="space-y-4">
        <div>
          <p class="text-xs font-medium text-zec-text mb-2">AppImage</p>
          <ol class="space-y-3 text-sm text-zec-muted list-none m-0 p-0">
            <li class="flex gap-3">
              <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">1</span>
              <div class="flex-1 min-w-0">
                <span>Make it executable and run:</span>
                <div class="mt-1.5 flex items-center gap-2 bg-zec-dark border border-zec-border rounded-lg px-3 py-2">
                  <code class="text-xs font-mono text-zec-text select-all flex-1 min-w-0" id="linux-appimage-cmd">chmod +x zecbox*.AppImage && ./zecbox*.AppImage</code>
                  <button
                    id="copy-btn-linux-appimage"
                    type="button"
                    class="shrink-0 p-1 rounded hover:bg-zec-border transition-colors text-zec-muted hover:text-zec-text copy-btn"
                    data-target="linux-appimage-cmd"
                    title="Copy to clipboard"
                  >
                    <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg>
                    <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </button>
                </div>
              </div>
            </li>
          </ol>
        </div>

        <div>
          <p class="text-xs font-medium text-zec-text mb-2">.deb (Debian/Ubuntu)</p>
          <ol class="space-y-3 text-sm text-zec-muted list-none m-0 p-0">
            <li class="flex gap-3">
              <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">1</span>
              <div class="flex-1 min-w-0">
                <span>Install the package:</span>
                <div class="mt-1.5 flex items-center gap-2 bg-zec-dark border border-zec-border rounded-lg px-3 py-2">
                  <code class="text-xs font-mono text-zec-text select-all flex-1 min-w-0" id="linux-deb-cmd">sudo dpkg -i zecbox*.deb</code>
                  <button
                    id="copy-btn-linux-deb"
                    type="button"
                    class="shrink-0 p-1 rounded hover:bg-zec-border transition-colors text-zec-muted hover:text-zec-text copy-btn"
                    data-target="linux-deb-cmd"
                    title="Copy to clipboard"
                  >
                    <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg>
                    <svg class="w-4 h-4 check-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </button>
                </div>
              </div>
            </li>
            <li class="flex gap-3">
              <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">2</span>
              <span>Launch <strong class="text-zec-text">ZecBox</strong> from your application menu</span>
            </li>
          </ol>
        </div>
      </div>
    </div>

    <script>
      // Generic copy handler for all copy buttons
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const targetId = btn.getAttribute('data-target');
          const cmd = document.getElementById(targetId)?.textContent ?? '';
          await navigator.clipboard.writeText(cmd);
          const copyIcon = btn.querySelector('.copy-icon');
          const checkIcon = btn.querySelector('.check-icon');
          if (copyIcon && checkIcon) {
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              checkIcon.classList.add('hidden');
            }, 2000);
          }
        });
      });
    </script>
  </div>
</section>
