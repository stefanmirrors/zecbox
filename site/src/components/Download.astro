---
let version = "0.1.2";
try {
  const res = await fetch("https://api.github.com/repos/stefanmirrors/zecbox/releases/latest");
  if (res.ok) {
    const data = await res.json();
    version = data.tag_name?.replace("v", "") ?? version;
  }
} catch {}
---

<section class="px-4 sm:px-6 py-12 sm:py-20">
  <div
    class="max-w-3xl mx-auto bg-zec-surface border border-zec-border rounded-xl sm:rounded-2xl p-6 sm:p-10 text-center space-y-6"
  >
    <h2 class="text-3xl font-bold text-zec-text">Ready to run your node?</h2>
    <p class="text-zec-muted max-w-lg mx-auto">
      macOS 12+ required. Apple Silicon and Intel supported. The Zcash
      blockchain needs approximately 300 GB of free disk space.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-aarch64.dmg"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg bg-zec-yellow text-zec-dark font-semibold text-lg hover:brightness-110 transition-all"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
        Apple Silicon
      </a>
      <a
        href="https://github.com/stefanmirrors/zecbox/releases/latest/download/zecbox-macos-x86_64.dmg"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg border border-zec-border text-zec-text font-semibold text-lg hover:border-zec-muted transition-all"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
        </svg>
        Intel
      </a>
    </div>
    <details class="text-left max-w-md mx-auto">
      <summary class="text-xs text-zec-muted cursor-pointer hover:text-zec-text transition-colors text-center">
        macOS showing a security warning?
      </summary>
      <div class="mt-3 text-sm text-zec-muted space-y-2">
        <p>Open Terminal and run:</p>
        <code class="block bg-zec-dark border border-zec-border rounded-lg px-4 py-2.5 text-zec-text text-xs font-mono select-all">xattr -cr /Applications/zecbox.app</code>
        <p class="text-xs">This removes the quarantine flag macOS applies to downloaded apps. Code signing is coming soon.</p>
      </div>
    </details>
    <p class="text-xs text-zec-muted">
      v{version} · Windows and Linux coming soon.
    </p>
  </div>
</section>
