      <div data-platform-divider class="border-t border-zec-border my-5"></div>

      <!-- Linux AppImage -->
      <div data-platform="linux-appimage">
        <span class="text-[10px] font-medium text-zec-muted bg-zec-dark border border-zec-border rounded px-1.5 py-0.5">Linux · AppImage</span>
        <ol class="space-y-3 text-sm text-zec-muted list-none m-0 p-0 mt-3">
