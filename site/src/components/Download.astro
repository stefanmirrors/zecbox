                <code class="text-xs font-mono text-zec-text select-all flex-1 min-w-0" id="linux-deb-cmd">sudo dpkg -i ~/Downloads/zecbox*.deb</code>
                <button type="button" class="shrink-0 p-1 rounded hover:bg-zec-border transition-colors text-zec-muted hover:text-zec-text copy-btn" data-target="linux-deb-cmd" title="Copy to clipboard">
                  <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg>
