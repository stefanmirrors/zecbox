      <p class="text-zec-muted">v{version} · ~300 GB disk space required for the full blockchain</p>
    </div>

    <!-- Download data for client-side detection -->
    <script id="download-data" type="application/json" set:html={JSON.stringify(downloads)} />

    <!-- Layer A: Auto-detected primary download (hidden until JS detects platform) -->
    <div id="detected-download" class="hidden max-w-sm mx-auto text-center mb-6">
