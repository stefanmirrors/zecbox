      </div>

      <!-- macOS -->
      <div data-platform="macos" class="mb-5">
        <span class="text-[10px] font-medium text-zec-muted bg-zec-dark border border-zec-border rounded px-1.5 py-0.5">macOS</span>
        <ol class="space-y-3 text-sm text-zec-muted list-none m-0 p-0 mt-3">
          <li class="flex gap-3">
            <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">1</span>
            <span>Open the <strong class="text-zec-text">.dmg</strong> and drag ZecBox into Applications</span>
          </li>
          <li class="flex gap-3">
            <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">2</span>
            <div class="flex-1 min-w-0">
              <span>Remove the quarantine flag, then open ZecBox:</span>
              <div class="mt-1.5 flex items-center gap-2 bg-zec-dark border border-zec-border rounded-lg px-3 py-2">
                <code class="text-xs font-mono text-zec-text select-all flex-1 min-w-0" id="xattr-cmd">xattr -cr /Applications/zecbox.app && open /Applications/zecbox.app</code>
                <button type="button" class="shrink-0 p-1 rounded hover:bg-zec-border transition-colors text-zec-muted hover:text-zec-text copy-btn" data-target="xattr-cmd" title="Copy to clipboard">
                  <svg class="w-4 h-4 copy-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" stroke-width="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/></svg>
