      <div data-platform="linux-deb">
        <span class="text-[10px] font-medium text-zec-muted bg-zec-dark border border-zec-border rounded px-1.5 py-0.5">Linux · .deb</span>
        <ol class="space-y-3 text-sm text-zec-muted list-none m-0 p-0 mt-3">
          <li class="flex gap-3">
            <span class="text-zec-yellow font-bold text-xs mt-0.5 shrink-0">1</span>
